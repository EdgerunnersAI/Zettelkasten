# CI-only Postgres image: supabase/postgres + pg_partman.
# Build at workflow time so `supabase start` boots with pg_partman pre-installed,
# eliminating runtime apt-get/apk install. Production unaffected (managed Supabase).
# Rationale + citations: docs/research/2026-05-12-pg-partman-ci.md.
# create_parent deferred per pganalyze 2023 (10M-row threshold).

ARG SUPABASE_POSTGRES_TAG=17.6.1.001
FROM supabase/postgres:${SUPABASE_POSTGRES_TAG}

USER root

# supabase/postgres:17.x is Debian-based but does NOT pre-configure PGDG apt.
# postgresql-17-partman lives in the PGDG repo, so we must register it first.
# Reference: https://www.postgresql.org/download/linux/debian/ (current 2024-2026).
RUN set -eux; \
    if command -v apt-get >/dev/null 2>&1; then \
        apt-get update; \
        apt-get install -y --no-install-recommends ca-certificates curl gnupg lsb-release; \
        install -d /usr/share/postgresql-common/pgdg; \
        curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc \
            | gpg --dearmor -o /usr/share/postgresql-common/pgdg/apt.postgresql.org.gpg; \
        . /etc/os-release; \
        echo "deb [signed-by=/usr/share/postgresql-common/pgdg/apt.postgresql.org.gpg] https://apt.postgresql.org/pub/repos/apt ${VERSION_CODENAME}-pgdg main" \
            > /etc/apt/sources.list.d/pgdg.list; \
        apt-get update; \
        apt-get install -y --no-install-recommends postgresql-17-partman; \
        apt-get purge -y --auto-remove curl gnupg lsb-release; \
        rm -rf /var/lib/apt/lists/*; \
    elif command -v apk >/dev/null 2>&1; then \
        apk add --no-cache git make gcc musl-dev postgresql17-dev; \
        git clone --depth 1 https://github.com/pgpartman/pg_partman /tmp/pg_partman; \
        cd /tmp/pg_partman && make NO_BGW=1 install; \
        rm -rf /tmp/pg_partman; \
        apk del git make gcc musl-dev postgresql17-dev; \
    else \
        echo "ERR: no supported package manager for pg_partman install" >&2; \
        exit 1; \
    fi

USER postgres
